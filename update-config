#!/bin/sh
set -e

platform=$1
version=$2

# Validate arguments
if [ -z "${platform}" ] || [ -z "${version}" ]; then
    echo "Usage: $0 <platform> <version>" >&2
    echo "  platform: e.g. aks-k8s, docker-compose, eks-k8s, gcp-k8s, minikube-k8s, ovh-k8s, scw-k8s, podman-compose" >&2
    echo "  version:  x.y.z format (e.g. 1.8.20)" >&2
    exit 1
fi

# Validate version is x.y.z format
if ! echo "${version}" | grep -qE '^[0-9]+\.[0-9]+\.[0-9]+$'; then
    echo "Error: version must be in x.y.z format (e.g. 1.8.20)" >&2
    exit 1
fi

# Extract x.y from x.y.z
template=$(echo "${version}" | cut -d. -f1,2)

tmpdir=$(mktemp -d)
trap 'rm -rf ${tmpdir}' EXIT

echo "Updating config for version ${version} (template ${template}, platform ${platform})..."

echo "Creating virtual environment..."
python3 -m venv ${tmpdir}
. ${tmpdir}/bin/activate

echo "Installing trustgraph-templates..."
pip install -q --no-cache --disable-pip-version-check --upgrade git+https://github.com/trustgraph-ai/trustgraph-templates@master

echo "Generating deployment artifacts..."
if [ "${platform}" = "docker-compose" ] || [ "${platform}" = "podman-compose" ]; then
    tg-build-deployment -i config.json -t ${template} -v ${version} --platform ${platform} --output deploy.zip
else
    tg-build-deployment -i config.json -t ${template} -v ${version} --platform ${platform} -R > resources.yaml
fi

echo "Done."
